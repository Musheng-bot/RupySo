{
  "version": 2,
  "builds": [
    {
      "src": "RupySo/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.10"
      }
    },
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "RupySo/wsgi.py"
    }
  ],
  "rewrites": [
    {
      "source": "/api/media-proxy",
      "destination": "/api/media-proxy"
    }
  ]
}
